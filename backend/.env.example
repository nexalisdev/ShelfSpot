# Database Configuration
# Local Docker/PostgreSQL default:
DATABASE_URL="postgresql://postgres:password@localhost:5432/shelfspot"
# Alternative for backend running inside docker-compose (service name "db"):
# DATABASE_URL="postgresql://postgres:password@db:5432/shelfspot"
# Alternative for external PostgreSQL server:
# DATABASE_URL="postgresql://username:password@your_db_host:5432/database_name"

# JWT Configuration
JWT_SECRET="your_jwt_secret_here"

# Email Configuration (Resend)
RESEND_API_KEY="your_resend_api_key_here"
RESEND_FROM_EMAIL="ShelfSpot <alerts@yourapp.com>"
ALERT_EMAIL_RECIPIENT="admin@yourapp.com"
