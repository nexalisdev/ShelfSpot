# Copy this file to .env.docker and fill in real values
# .env.docker is gitignored — never commit secrets

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/shelfspot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=shelfspot

# Auth
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARS

# CORS — URL of the frontend (used by backend to restrict CORS)
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=ShelfSpot <noreply@yourdomain.com>
ALERT_EMAIL_RECIPIENT=admin@yourdomain.com
